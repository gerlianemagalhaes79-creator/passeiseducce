{
  "entities": {
    "AirConditioner": {
      "title": "Air Conditioner",
      "description": "Represents an air conditioner unit in the Polyclinic",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tagId": { "type": "string", "description": "Patrimônio/Identificação" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "capacity": { "type": "number", "description": "Capacidade em BTUs" },
        "location": { "type": "string", "description": "Setor/Sala" },
        "status": { "type": "string", "enum": ["operating", "needs_maintenance", "in_maintenance", "inactive"] },
        "installationDate": { "type": "string", "format": "date" },
        "lastPreventiveDate": { "type": "string", "format": "date" },
        "nextPreventiveDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tagId", "brand", "model", "capacity", "location", "status"]
    },
    "MaintenanceLog": {
      "title": "Maintenance Log",
      "description": "Represents a preventive or corrective maintenance ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "airConditionerId": { "type": "string" },
        "airConditionerTag": { "type": "string" },
        "airConditionerLocation": { "type": "string" },
        "type": { "type": "string", "enum": ["preventive", "corrective"] },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "description": { "type": "string", "description": "Relato do problema ou escopo" },
        "checklist": { "type": "array", "description": "Checklist de preventiva" },
        "technician": { "type": "string", "description": "Técnico responsável" },
        "resolution": { "type": "string", "description": "Detalhes da solução" },
        "scheduledDate": { "type": "string", "format": "date" },
        "completionDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "diagnostics": { "type": "string", "description": "IA Diagnóstico" }
      },
      "required": ["id", "airConditionerId", "type", "status", "priority", "description", "createdAt"]
    }
  },
  "firestore": {
    "air_conditioners": {
      "schema": "AirConditioner",
      "description": "Collection of all air conditioning units"
    },
    "maintenance_logs": {
      "schema": "MaintenanceLog",
      "description": "Collection of all maintenance tickets and logs"
    }
  }
}
