{
  "entities": {
    "AuthorizedUser": {
      "title": "Authorized User",
      "description": "Represents a whitelisted user allowed to access the platform",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "The normalized lowercase Google account email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "CandidateSetting": {
      "title": "Candidate Setting",
      "description": "Saves candidate configurations and specialties",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetExam": { "type": "string" },
        "examBoard": { "type": "string" },
        "specialty": { "type": "string" },
        "examDate": { "type": "string" },
        "dailyStudyHours": { "type": "number" },
        "candidateName": { "type": "string" },
        "isAlreadyTeacher": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "targetExam", "examBoard", "specialty", "examDate", "dailyStudyHours", "createdAt"]
    }
  },
  "firestore": {
    "authorized_users": {
      "schema": "AuthorizedUser",
      "description": "Whitelisted emails for platform login"
    },
    "candidate_settings": {
      "schema": "CandidateSetting",
      "description": "User specific configurations"
    },
    "content_topics": {
      "schema": { "$ref": "#/entities/ContentTopic" },
      "description": "All exam syllabus content and progression status"
    },
    "study_activities": {
      "schema": { "$ref": "#/entities/StudyActivity" },
      "description": "Strategic planned daily study milestones"
    },
    "questions": {
      "schema": { "$ref": "#/entities/Question" },
      "description": "Exam questions database"
    },
    "mistake_records": {
      "schema": { "$ref": "#/entities/MistakeRecord" },
      "description": "Mistakes tracker notebook"
    }
  }
}
