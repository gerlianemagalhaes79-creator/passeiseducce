rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Regras para a coleção de usuários autorizados
    match /authorized_users/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.email == "gerlianemagalhaes79@gmail.com" ||
        exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email))
      );
    }
    
    // 2. Regras globais para os demais documentos do Aprova Professor
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.email == "gerlianemagalhaes79@gmail.com" ||
        exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email))
      );
    }
  }
}
